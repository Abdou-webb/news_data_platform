# ============================================================
# Template — copy this file to .env and fill in your values.
# The .env file is in .gitignore and will NEVER be committed.
# ============================================================

# ── Storage backend ─────────────────────────────────────────
# "minio"  → local Docker (default)
# "s3"     → AWS S3 (cloud/production)
STORAGE_BACKEND=minio

# ── MinIO (local data lake) ─────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=your_minio_user
MINIO_SECRET_KEY=your_minio_password

# ── AWS S3 (cloud data lake — used when STORAGE_BACKEND=s3) ─
AWS_REGION=eu-west-1
AWS_S3_BUCKET=your-bucket-name
# Leave blank on EC2 with IAM role attached (recommended)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── PostgreSQL — Data Warehouse (Gold layer) ─────────────────
PG_HOST=postgres-dw
PG_PORT=5432
PG_USER=your_dw_user
PG_PASSWORD=your_dw_password
PG_DB=datawarehouse

# ── PostgreSQL — Metabase internal DB ────────────────────────
METABASE_DB_USER=your_metabase_user
METABASE_DB_PASSWORD=your_metabase_password

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC=news_articles_raw
STREAMING_ARTICLES_PER_RUN=20
STREAMING_DELAY_SEC=0.5
CONSUMER_TIMEOUT_MS=30000

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_password
